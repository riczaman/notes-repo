  <diagram name="Contractor — Extension Over Tenure" id="diagram1">
    <mxGraphModel dx="1800" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="c2" value="Contractor — Extension Over Tenure" style="text;html=1;fontSize=14;fontStyle=1;align=left;verticalAlign=middle;fontColor=#0E2E1C;" vertex="1" parent="1"><mxGeometry x="20" y="10" width="900" height="30" as="geometry"/></mxCell>
<mxCell id="c3" value="1. EMS Intake Triage
(Type of Expense: Approval to Hire)" style="shape=document;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="20" y="60" width="160" height="70" as="geometry"/></mxCell>
<mxCell id="c4" value="2. Select Resource Type: Contractor" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="240" y="60" width="160" height="70" as="geometry"/></mxCell>
<mxCell id="c6" value="3. Is this an extension over tenure?
(Decision point)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="460" y="60" width="160" height="70" as="geometry"/></mxCell>
<mxCell id="c8" value="4a. If NO: Continue to ATH / Signing Portal
(Standard contractor path)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="680" y="60" width="160" height="70" as="geometry"/></mxCell>
<mxCell id="c9" value="No pipeline required." style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff9b2;strokeColor=#d6b656;fontSize=10;size=14;" vertex="1" parent="1"><mxGeometry x="680" y="144" width="160" height="60" as="geometry"/></mxCell>
<mxCell id="c11" value="PHASE: Pipeline Branch (if Extension = Yes)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F2F7F3;strokeColor=#C7E0CD;fontSize=12;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;fontColor=#1F6B3A;" vertex="1" parent="1"><mxGeometry x="10" y="184" width="900" height="26" as="geometry"/></mxCell>
<mxCell id="c12" value="4b. If YES: Is pipeline already approved?
(Tenure extension requires pipeline)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="20" y="220" width="160" height="70" as="geometry"/></mxCell>
<mxCell id="c13" value="5. Pipeline NOT Approved: Go to Pipeline Intake
(User completes pipeline first)" style="shape=document;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="240" y="220" width="160" height="70" as="geometry"/></mxCell>
<mxCell id="c14" value="User creates pipeline, returns, re-enters contractor ATH flow with new pipeline ID." style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff9b2;strokeColor=#d6b656;fontSize=10;size=14;" vertex="1" parent="1"><mxGeometry x="240" y="304" width="160" height="60" as="geometry"/></mxCell>
<mxCell id="c16" value="6. Pipeline Approved: Provide Pipeline ID
(System validates against pipeline table)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="460" y="220" width="160" height="70" as="geometry"/></mxCell>
<mxCell id="c17" value="Continue button disabled if invalid pipeline ID entered." style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff9b2;strokeColor=#d6b656;fontSize=10;size=14;" vertex="1" parent="1"><mxGeometry x="460" y="304" width="160" height="60" as="geometry"/></mxCell>
<mxCell id="c19" value="7. Valid Pipeline ID: Continue to ATH Intake" style="shape=document;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="680" y="220" width="160" height="70" as="geometry"/></mxCell>
<mxCell id="c21" value="8. ATH Approval Flow
(AVP -&gt; VP -&gt; SVP -&gt; EVP (pending LOB))" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="900" y="220" width="160" height="70" as="geometry"/></mxCell>
