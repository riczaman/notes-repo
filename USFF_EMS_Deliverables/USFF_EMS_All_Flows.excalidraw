{"type":"text","id":"f2_note2","x":555,"y":1010,"width":240,"height":83,"text":"All interim approvals live on BOM\nagendas driven by intake status;\nonly the final SEVP (Vlad)\napproval is stamped on the\nintake. ATH NEVER routes to\nMgmt Consulting.","originalText":"All interim approvals live on BOM\nagendas driven by intake status;\nonly the final SEVP (Vlad)\napproval is stamped on the\nintake. ATH NEVER routes to\nMgmt Consulting.","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#64748b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":2059,"version":1,"versionNonce":2060,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
{"type":"text","id":"f2_note4","x":1040,"y":1010,"width":215,"height":56,"text":"❗ Appears to be an offline step\n— hiring manager works directly\nwith the vendor. Confirm if it\nis tracked in any system.","originalText":"❗ Appears to be an offline step\n— hiring manager works directly\nwith the vendor. Confirm if it\nis tracked in any system.","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#b91c1c","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":2061,"version":1,"versionNonce":2062,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
