{"type":"text","id":"f3_note1","x":290,"y":1400,"width":240,"height":69,"text":"ATH reuse rule: same ATH can be\nreused if the vendor swaps within\nTCS / Cognizant / Wipro or the\nrate goes DOWN. Any other vendor\nor a rate increase = new SPID.","originalText":"ATH reuse rule: same ATH can be\nreused if the vendor swaps within\nTCS / Cognizant / Wipro or the\nrate goes DOWN. Any other vendor\nor a rate increase = new SPID.","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#64748b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":3059,"version":1,"versionNonce":3060,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
